	  xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>nextinject</id>
	<name>NextInject</name>
	<summary>Systemweite Dateimarker und Public-Share-Aktionen</summary>
	<description><![CDATA[
		NextInject markiert Dateien und Freigaben anhand definierter Namensmuster
		mit typisierten Badges und Public-Share-Aktionen. Administratoren pflegen
		die Regeln zentral, ohne freies HTML oder Theme-Hardcoding.
	]]></description>
	<version>2.0.1</version>
	<licence>agpl</licence>
