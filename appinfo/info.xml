	<namespace>NextInject</namespace>
	<category>files</category>
	<category>tools</category>
	<website>https://github.com/Yxanu/nextinject</website>
	<bugs>https://github.com/Yxanu/nextinject/issues</bugs>
	<repository type="git">https://github.com/Yxanu/nextinject.git</repository>
	<screenshot>https://raw.githubusercontent.com/Yxanu/nextinject/main/img/nextinject.png</screenshot>
	<dependencies>
		<nextcloud min-version="31" max-version="32"/>
	</dependencies>
	<settings>
		<admin>OCA\NextInject\Settings\Admin</admin>
	</settings>
</info>
